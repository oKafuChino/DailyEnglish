# Telegram
BOT_TOKEN=
OWNER_TELEGRAM_ID=

# Database used by Docker Compose
POSTGRES_DB=dailyenglish
POSTGRES_USER=dailyenglish
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+asyncpg://dailyenglish:change-me@postgres:5432/dailyenglish

# Use a long, random secret. It is used to derive stored invite-code digests.
INVITE_CODE_PEPPER=

# Application
APP_TIMEZONE=Asia/Shanghai
DEFAULT_PUSH_HOUR=8
DEFAULT_PUSH_MINUTE=0
WORKER_POLL_INTERVAL_SECONDS=60
DELIVERY_RETRY_MINUTES=5
DELIVERY_MAX_ATTEMPTS=3
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_DEFAULT_REQUESTS=30
RATE_LIMIT_CONTENT_REQUESTS=10
RATE_LIMIT_CALLBACK_REQUESTS=30
RATE_LIMIT_ADMIN_REQUESTS=20
RATE_LIMIT_REGISTRATION_REQUESTS=5
RATE_LIMIT_REGISTRATION_WINDOW_SECONDS=300
LOG_LEVEL=INFO

# Optional content providers
DICTIONARY_API_KEY=
LLM_API_KEY=
